# ============================================================
# TrustPay Backend - Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to git
# ============================================================

# Application
APP_NAME=TrustPay
APP_VERSION=1.0.0
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
APP_ALLOWED_HOSTS=["localhost","127.0.0.1"]
APP_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Database
DATABASE_URL=postgresql+asyncpg://trustpay:trustpay_pass@localhost:5432/trustpay_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_64_AT_MINIMUM
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Admin defaults (change after first run)
ADMIN_EMAIL=admin@trustpay.local
ADMIN_PASSWORD=Admin@TrustPay2024!

# Storage (S3-compatible)
STORAGE_ENDPOINT=https://s3.amazonaws.com
STORAGE_ACCESS_KEY=CHANGE_ME
STORAGE_SECRET_KEY=CHANGE_ME
STORAGE_BUCKET=trustpay-uploads
STORAGE_REGION=us-east-1

# Email (SMTP)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=noreply@trustpay.local

# Telegram
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_KYC_BOT_TOKEN=CHANGE_ME
